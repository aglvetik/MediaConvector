BOT_TOKEN=
BOT_MODE=polling
DATABASE_URL=sqlite+aiosqlite:///runtime/bot.db
LOG_LEVEL=INFO
TEMP_DIR=runtime/tmp
MAX_PARALLEL_DOWNLOADS=2
MAX_PARALLEL_FFMPEG=2
MAX_FILE_SIZE_MB=45
REQUEST_TIMEOUT_SECONDS=20
DOWNLOAD_TIMEOUT_SECONDS=120
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp
YTDLP_COOKIES_FILE=
RATE_LIMIT_ENABLED=true
USER_REQUESTS_PER_MINUTE=4
USER_REQUEST_COOLDOWN_SECONDS=3
MAX_MUSIC_QUERY_LENGTH=120
MUSIC_SEARCH_TIMEOUT_SECONDS=15
MUSIC_RESOLVER_MAX_CANDIDATES=3
MUSIC_STRATEGY_ORDER=youtube_cookies,youtube_no_cookies
YOUTUBE_AUTH_FAIL_THRESHOLD=2
YOUTUBE_DEGRADE_TTL_MINUTES=30
MUSIC_AUDIO_ONLY=true
COOKIE_HEALTHCHECK_ENABLED=true
TEMP_FILE_TTL_MINUTES=30
CLEANUP_INTERVAL_MINUTES=10
HEALTH_INTERVAL_MINUTES=15
JOB_STALE_AFTER_MINUTES=15
