BOT_TOKEN=
APP_ENV=development
BOT_MODE=polling
DATABASE_URL=sqlite+aiosqlite:///runtime/bot.db
LOG_LEVEL=INFO
TEMP_DIR=runtime/tmp
MAX_PARALLEL_DOWNLOADS=2
MAX_PARALLEL_FFMPEG=2
MAX_FILE_SIZE_MB=45
REQUEST_TIMEOUT_SECONDS=20
DOWNLOAD_TIMEOUT_SECONDS=120
FFMPEG_PATH=
YTDLP_PATH=yt-dlp
RATE_LIMIT_ENABLED=true
USER_REQUESTS_PER_MINUTE=4
TEMP_FILE_TTL_MINUTES=30
CLEANUP_INTERVAL_MINUTES=10
HEALTH_INTERVAL_MINUTES=15
JOB_STALE_AFTER_MINUTES=15